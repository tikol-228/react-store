{
  "name": "react-store",
  "version": "1.0.0",
  "description": "Full-stack React e-commerce store",
  "scripts": {
    "build": "node scripts/railway-build.mjs",
    "start": "node scripts/railway-start.mjs",
    "install-all": "npm install && npm install --prefix server && npm install --prefix my-app",
    "postinstall": "npm install --prefix server --omit=dev",
    "kill-api-port": "sh -c 'lsof -ti :5000 | xargs -r kill -9 2>/dev/null || true'",
    "dev": "npm run kill-api-port && concurrently \"npm run dev --prefix server\" \"npm run dev --prefix my-app\"",
    "install-server": "npm install --prefix server",
    "install-client": "npm install --prefix my-app",
    "railway": "npx @railway/cli",
    "deploy:login": "npx @railway/cli login",
    "deploy:status": "npx @railway/cli status",
    "deploy:web": "cd my-app && npx @railway/cli up --service web --detach",
    "deploy:api": "cd server && npx @railway/cli up --service api --detach",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "devDependencies": {
    "@railway/cli": "^4.58.0",
    "concurrently": "^8.2.2",
    "wrangler": "^4.100.0"
  }
}
