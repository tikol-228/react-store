# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DB_PATH=./database/store.db

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Доп. PIN для экрана /admin (после входа учётной записью с ролью admin). Оставьте пустым — без второго шага.
ADMIN_PANEL_PIN=storepanel