PORT=5000
NODE_ENV=production

# SQLite (на Railway: том /data → DB_PATH=/data/store.db)
DB_PATH=./database/store.db

JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

ADMIN_EMAIL=admin@store.com
ADMIN_PASSWORD=admin123
ADMIN_PANEL_PIN=storepanel

# URL фронтенда через запятую (CORS)
FRONTEND_URL=https://your-frontend.up.railway.app

# false — не запускать seed при старте
# RUN_SEED=false
