{
  "name": "react-store-backend",
  "version": "1.0.0",
  "description": "Backend for React Store with Node.js, Express, and SQLite",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "railway:build": "npm install",
    "dev": "node --watch src/server.js",
    "init-db": "node src/db/init.js",
    "seed": "node src/db/seed.js",
    "seed:demo-orders": "node src/db/seedDemoOrders.js",
    "clear:demo": "node --input-type=module -e \"import { clearAllDemoData } from './src/db/seedDemoOrders.js'; const r = await clearAllDemoData(); console.log(r);\"",
    "clear:products": "node src/db/clearProducts.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.6",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "nodejs",
    "express",
    "sqlite",
    "react",
    "ecommerce"
  ],
  "author": "Your Name",
  "license": "MIT"
}
